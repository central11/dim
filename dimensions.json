    "id": "mni24jfuxgom7xoy4ga",
    "type": "calc",
    "name": "Pediment Height Calculator",
    "notes": "The total height of a pediment if you have the width",
    "category": "architectural",
    "subcat": "architectural-traditional-features",
    "software": "Both",
    "btypes": [
      "residential",
      "commercial",
      "mixed-use",
      "industrial",
      "hospitality",
      "healthcare",
      "education",
      "civic"
    ],
    "vars": [
      {
        "label": "Pediment Width",
        "unit": "ft"
      },
      {
        "label": "Number of Columns",
        "unit": "num"
      }
    ],
    "formulas": [
      {
        "label": "Pediment Height",
        "expr": "(4 * Pediment Width)/(14 + Number of Columns)",
        "unit": "in"
      }
    ],
